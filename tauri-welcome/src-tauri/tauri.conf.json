{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tauri Welcome",
  "version": "0.1.0",
  "identifier": "com.usbboot.tauriwelcome",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Welcome",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
