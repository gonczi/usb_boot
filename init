#!/bin/sh

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Mount essential filesystems
/bin/busybox mountpoint -q /proc 2>/dev/null || /bin/busybox mount -t proc none /proc
/bin/busybox mountpoint -q /sys  2>/dev/null || /bin/busybox mount -t sysfs none /sys
/bin/busybox mountpoint -q /dev  2>/dev/null || /bin/busybox mount -t devtmpfs none /dev
[ -d /dev/pts ] || mkdir -p /dev/pts
/bin/busybox mountpoint -q /dev/pts 2>/dev/null || /bin/busybox mount -t devpts devpts /dev/pts

# Set root password to 'alpine'
if command -v chpasswd >/dev/null 2>&1; then
    if echo "root:alpine" | chpasswd; then
        echo "Root password configured."
    else
        echo "WARNING: Failed to set root password via chpasswd"
        [ -f /etc/shadow ] || echo "WARNING: /etc/shadow missing"
    fi
else
    echo "WARNING: chpasswd not found"
fi

# Load network driver early so DHCP can succeed
modprobe e1000 2>/dev/null || echo "e1000 load failed"

# Load input stack so wlroots/cage can receive pointer and keyboard events in VM.
for module in serio_raw atkbd psmouse evdev mousedev hid usbhid virtio_input; do
    modprobe "$module" 2>/dev/null || true
done

# Load only minimal generic graphics modules for Wayland/WebKitGTK runtime.
# Avoid loading all vendor drivers at once (i915/amdgpu/nouveau), which can bloat
# initramfs boot and create noisy/conflicting probe attempts in VMs.
for module in drm drm_kms_helper simpledrm virtio_gpu; do
    modprobe "$module" 2>/dev/null || true
done

# Start eudev for proper udev device metadata (libinput requires this)
if [ -x /sbin/udevd ]; then
    echo "Starting eudev..."
    /sbin/udevd --daemon
    sleep 1
    /sbin/udevadm trigger --action=add
    /sbin/udevadm settle --timeout=10
fi

sleep 2

# Setup network
ip link set lo up

# Wait for eth0 to appear and configure it
ETH_FOUND=0
for i in 1 2 3 4 5; do
    if ip link show eth0 2>/dev/null; then
        ip link set eth0 up
        ETH_FOUND=1
        break
    fi
    sleep 1
done

if [ $ETH_FOUND -eq 1 ]; then
    # Get IP address via DHCP with timeout
    timeout 10 udhcpc -i eth0 -s /usr/share/udhcpc/default.script >/dev/null 2>&1
else
    # Set static IP if DHCP fails
    ip addr add 10.0.2.15/24 dev lo
fi

# Regenerate library symlinks BEFORE starting SSH
if ! ldconfig 2>/dev/null; then
    # Create symlinks for shared libraries
    for dir in /lib /usr/lib; do
        if [ -d "$dir" ]; then
            cd "$dir"
            for lib in *.so.*; do
                [ -f "$lib" ] || continue
                # Extract base name (e.g., libexpat.so.1 from libexpat.so.1.9.2)
                base=$(echo "$lib" | sed -E 's/(\.so\.[0-9]+).*/\1/')
                if [ "$base" != "$lib" ] && [ ! -e "$base" ]; then
                    ln -sf "$lib" "$base"
                fi
            done
        fi
    done
    cd /
fi

# Start SSH server
mkdir -p /var/empty /var/run /run
mkdir -p /etc/ssh
mkdir -p /etc/ssh/sshd_config.d
mkdir -p /root/.ssh
chmod 700 /root/.ssh

# Allow password SSH login for root in this kiosk image.
cat > /etc/ssh/sshd_config.d/10-root-password.conf <<'EOF'
PermitRootLogin yes
PasswordAuthentication yes
KbdInteractiveAuthentication no
EOF

# Generate host keys if they don't exist
if [ ! -f /etc/ssh/ssh_host_rsa_key ]; then
    if command -v ssh-keygen >/dev/null 2>&1; then
        ssh-keygen -A >/dev/null 2>&1
    else
        echo "ssh-keygen not found, skipping key generation"
    fi
fi

# Start sshd
SSHD_PATH=""

# Try to find sshd
for path in /usr/sbin/sshd /sbin/sshd /usr/bin/sshd /bin/sshd; do
    if [ -x "$path" ]; then
        SSHD_PATH="$path"
        break
    fi
done

# If not found in standard paths, search the filesystem
if [ -z "$SSHD_PATH" ]; then
    SSHD_PATH=$(find / -name "sshd" -type f -perm /u+x 2>/dev/null | head -1)
fi

if [ -n "$SSHD_PATH" ]; then
    "$SSHD_PATH" -D &
else
    echo "WARNING: sshd binary not found!"
    echo "Available SSH-related files:"
    find / -name "*ssh*" -type f 2>/dev/null | head -20
fi

# Scan sysfs and populate /dev (needed when kernel auto-mounted devtmpfs before init)
/bin/busybox mdev -s 2>/dev/null || true

echo "kiosk-tauri elindult"

# Start kiosk app on TTY1 via cage Wayland compositor
export XDG_RUNTIME_DIR=/run/user/0
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR"

# seatd is needed for cage to access DRM without root privilege dance
seatd -g root &
sleep 1

if [ ! -x /usr/bin/Xwayland ]; then
    echo "WARNING: /usr/bin/Xwayland is missing; cage may fail to start" >> /run/kiosk.log
fi

# Launch cage with the Tauri kiosk app on TTY1.
# openvt may not preserve env reliably, so export vars in a child script.
cat > /run/start-kiosk.sh <<'EOF'
#!/bin/sh
export XDG_RUNTIME_DIR=/run/user/0
export WLR_RENDERER_ALLOW_SOFTWARE=1
export WLR_NO_HARDWARE_CURSORS=1
export GDK_BACKEND=wayland
export WEBKIT_DISABLE_COMPOSITING_MODE=0
export XCURSOR_THEME=Adwaita
export XCURSOR_SIZE=24
export XKB_DEFAULT_RULES=evdev
export XKB_DEFAULT_MODEL=pc105
export XKB_DEFAULT_LAYOUT=us

# Launch cage (udevadm settle already ensured devices are ready)
exec cage /opt/kiosk/tauri_welcome >>/run/kiosk.log 2>&1
EOF
chmod +x /run/start-kiosk.sh


openvt -c 1 -s -w -- /run/start-kiosk.sh &

exec sleep infinity
