#!/bin/sh

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Mount essential filesystems
/bin/busybox mountpoint -q /proc 2>/dev/null || /bin/busybox mount -t proc none /proc
/bin/busybox mountpoint -q /sys  2>/dev/null || /bin/busybox mount -t sysfs none /sys
/bin/busybox mountpoint -q /dev  2>/dev/null || /bin/busybox mount -t devtmpfs none /dev
[ -d /dev/pts ] || mkdir -p /dev/pts
/bin/busybox mountpoint -q /dev/pts 2>/dev/null || /bin/busybox mount -t devpts devpts /dev/pts

# Set root password to 'alpine'
if command -v chpasswd >/dev/null 2>&1; then
    if echo "root:alpine" | chpasswd; then
        echo "Root password configured."
    else
        echo "WARNING: Failed to set root password via chpasswd"
        [ -f /etc/shadow ] || echo "WARNING: /etc/shadow missing"
    fi
else
    echo "WARNING: chpasswd not found"
fi

# Load network driver early so DHCP can succeed
echo "Loading network driver..."
modprobe e1000 2>/dev/null || echo "e1000 load failed"
sleep 2

# Setup network
echo "Setting up network..."
ip link set lo up

# Wait for eth0 to appear and configure it
ETH_FOUND=0
for i in 1 2 3 4 5; do
    if ip link show eth0 2>/dev/null; then
        echo "eth0 found"
        ip link set eth0 up
        ETH_FOUND=1
        break
    fi
    echo "Waiting for eth0... ($i/5)"
    sleep 1
done

if [ $ETH_FOUND -eq 1 ]; then
    # Get IP address via DHCP with timeout
    echo "Getting IP via DHCP..."
    timeout 10 udhcpc -i eth0 -s /usr/share/udhcpc/default.script 2>&1 | grep -v "^udhcpc:"
    echo "DHCP attempt complete"
    # Show IP address
    ip addr show eth0
else
    echo "eth0 not found, using static IP"
    # Set static IP if DHCP fails
    ip addr add 10.0.2.15/24 dev lo
fi

# Regenerate library symlinks BEFORE starting SSH
echo "Regenerating library cache..."
if ! ldconfig 2>/dev/null; then
    echo "ldconfig not available, creating symlinks manually..."
    # Create symlinks for shared libraries
    for dir in /lib /usr/lib; do
        if [ -d "$dir" ]; then
            cd "$dir"
            echo "Processing $dir..."
            for lib in *.so.*; do
                [ -f "$lib" ] || continue
                # Extract base name (e.g., libexpat.so.1 from libexpat.so.1.9.2)
                base=$(echo "$lib" | sed -E 's/(\.so\.[0-9]+).*/\1/')
                if [ "$base" != "$lib" ] && [ ! -e "$base" ]; then
                    echo "  Creating symlink: $base -> $lib"
                    ln -sf "$lib" "$base"
                fi
            done
        fi
    done
    cd /
    echo "Library symlinks created."
fi

# Start SSH server
mkdir -p /var/empty /var/run /run
mkdir -p /etc/ssh
mkdir -p /etc/ssh/sshd_config.d
mkdir -p /root/.ssh
chmod 700 /root/.ssh

# Allow password SSH login for root in this kiosk image.
cat > /etc/ssh/sshd_config.d/10-root-password.conf <<'EOF'
PermitRootLogin yes
PasswordAuthentication yes
KbdInteractiveAuthentication no
EOF

# Generate host keys if they don't exist
if [ ! -f /etc/ssh/ssh_host_rsa_key ]; then
    echo "Generating SSH host keys..."
    if command -v ssh-keygen >/dev/null 2>&1; then
        ssh-keygen -A 2>&1
    else
        echo "ssh-keygen not found, skipping key generation"
    fi
fi

# Start sshd
echo "Starting SSH server..."
SSHD_PATH=""

# Try to find sshd
for path in /usr/sbin/sshd /sbin/sshd /usr/bin/sshd /bin/sshd; do
    if [ -x "$path" ]; then
        SSHD_PATH="$path"
        break
    fi
done

# If not found in standard paths, search the filesystem
if [ -z "$SSHD_PATH" ]; then
    SSHD_PATH=$(find / -name "sshd" -type f -perm /u+x 2>/dev/null | head -1)
fi

if [ -n "$SSHD_PATH" ]; then
    echo "Found sshd at: $SSHD_PATH"
    "$SSHD_PATH" -D &
    SSHD_PID=$!
    echo "SSH server started (PID: $SSHD_PID)"
    echo "Login: root / password: alpine"
    echo "SSH from host: ssh root@localhost -p 2222"
else
    echo "WARNING: sshd binary not found!"
    echo "Available SSH-related files:"
    find / -name "*ssh*" -type f 2>/dev/null | head -20
fi

# Load framebuffer modules
echo "Loading video/framebuffer modules..."
modprobe drm 2>/dev/null || echo "drm load failed"
modprobe drm_kms_helper 2>/dev/null || echo "drm_kms_helper load failed"
modprobe bochs 2>/dev/null || echo "bochs load failed"

# Scan sysfs and populate /dev (needed when kernel auto-mounted devtmpfs before init)
echo "Running mdev -s to populate /dev from sysfs..."
/bin/busybox mdev -s 2>/dev/null || true

echo "======================================"
echo "  Booting Custom Alpine Linux System "
echo "======================================"
echo ""

# Execute run.sh script if exists
if [ -f /root/run.sh ]; then
    /root/run.sh
fi

echo "Starting Kiosk Mode..."

# Rebuild font cache so fbi can find fonts
echo "Building font cache..."
/usr/bin/fc-cache -f 2>/dev/null || echo "fc-cache not available"

echo "Checking for framebuffer device..."
ls -l /dev/fb* 2>&1
echo "Checking if fbi is available..."
ls -l /usr/bin/fbi 2>&1

# Display image on framebuffer in kiosk mode
if [ -c /dev/fb0 ]; then
    echo "Framebuffer found, displaying image..."
    # Wait a moment for framebuffer to be fully ready
    sleep 1
    
    # Get framebuffer info
    echo "FB resolution:"
    cat /sys/class/graphics/fb0/virtual_size 2>/dev/null || echo "Could not read virtual_size"
    echo "FB bits per pixel:"
    cat /sys/class/graphics/fb0/bits_per_pixel 2>/dev/null || echo "Could not read bits_per_pixel"
    echo "FB name:"
    cat /sys/class/graphics/fb0/name 2>/dev/null || echo "Could not read name"
    
    # Disable kernel messages on console
    echo "Disabling kernel printk..."
    echo 0 > /proc/sys/kernel/printk
    
    # Clear the framebuffer (black)
    dd if=/dev/zero of=/dev/fb0 bs=3145728 count=1 2>/dev/null
    
    # Display actual image using fbifájlokat másol vagy egyszerű host-ol
    if [ -f /root/kiosk-image.png ]; then
        echo "Displaying kiosk image..."
        /usr/bin/fbi -d /dev/fb0 -a -noverbose --autozoom -1 /root/kiosk-image.png </dev/tty1 >/dev/null 2>&1 &
        FBI_PID=$!
        sleep 2
        if kill -0 $FBI_PID 2>/dev/null; then
            echo "fbi is running (PID: $FBI_PID)"
        else
            echo "WARNING: fbi exited, trying alternative display..."
            # Fallback: try without tty redirect
            /usr/bin/fbi -d /dev/fb0 -a -noverbose --autozoom -1 -T 1 /root/kiosk-image.png </dev/null >/dev/null 2>&1 &
            FBI_PID=$!
            sleep 2
            if kill -0 $FBI_PID 2>/dev/null; then
                echo "fbi running with -T 1 (PID: $FBI_PID)"
            else
                echo "fbi failed, dumping error output..."
                /usr/bin/fbi -d /dev/fb0 -a --autozoom -1 /root/kiosk-image.png 2>&1 || true
            fi
        fi
    else
        echo "ERROR: /root/kiosk-image.png not found!"
        ls -la /root/
    fi
else
    echo "ERROR: Framebuffer /dev/fb0 not found!"
    echo "Falling back to shell..."
fi
exec sleep infinity
