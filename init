#!/bin/sh

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Boot timing log: readable via 'cat /run/boot-timing.log' after boot
TLOG=/run/boot-timing.log
_ts() { [ -r /proc/uptime ] && echo "$(cut -d' ' -f1 /proc/uptime) $*" >> "$TLOG" 2>/dev/null || true; }

_ts "init: START"

# Mount essential filesystems
/bin/busybox mountpoint -q /proc 2>/dev/null || /bin/busybox mount -t proc none /proc
/bin/busybox mountpoint -q /sys  2>/dev/null || /bin/busybox mount -t sysfs none /sys
/bin/busybox mountpoint -q /dev  2>/dev/null || /bin/busybox mount -t devtmpfs none /dev

[ -d /run ] || mkdir -p /run
/bin/busybox mountpoint -q /run 2>/dev/null || /bin/busybox mount -t tmpfs -o mode=0755,size=64m tmpfs /run

_ts "mounts: done"

# Load input stack so wlroots/cage can receive pointer and keyboard events in VM.
for module in serio_raw atkbd psmouse evdev mousedev hid usbhid virtio_input; do
    modprobe "$module" 2>/dev/null || true
done

_ts "modprobe input: done"

# Load only minimal generic graphics modules for Wayland/WebKitGTK runtime.
for module in drm drm_kms_helper simpledrm virtio_gpu; do
    modprobe "$module" 2>/dev/null || true
done

_ts "modprobe drm: done"

# Load network driver early (opcionális, mert az udev is betöltené, de ártani nem használ)
modprobe e1000 2>/dev/null || echo "e1000 load failed"

_ts "udevd: START"
if [ -x /sbin/udevd ]; then
    /sbin/udevd --daemon
    
    /sbin/udevadm trigger --action=add --type=subsystems
    /sbin/udevadm trigger --action=add --type=devices
    
    /sbin/udevadm settle --timeout=10
fi

_ts "udevd settle: done"

[ -d /dev/pts ] || mkdir -p /dev/pts
/bin/busybox mountpoint -q /dev/pts 2>/dev/null || /bin/busybox mount -t devpts devpts /dev/pts

[ -d /dev/shm ] || mkdir -p /dev/shm
/bin/busybox mountpoint -q /dev/shm 2>/dev/null || /bin/busybox mount -t tmpfs -o mode=1777,size=64m tmpfs /dev/shm

[ -d /tmp ] || mkdir -p /tmp
/bin/busybox mountpoint -q /tmp 2>/dev/null || /bin/busybox mount -t tmpfs -o mode=1777,size=128m tmpfs /tmp

# cgroups v2
[ -d /sys/fs/cgroup ] || mkdir -p /sys/fs/cgroup
/bin/busybox mountpoint -q /sys/fs/cgroup 2>/dev/null || /bin/busybox mount -t cgroup2 none /sys/fs/cgroup

/sbin/ip link set lo up

# Regenerate library symlinks BEFORE starting kiosk
if ! ldconfig 2>/dev/null; then
    # Create symlinks for shared libraries
    for dir in /lib /usr/lib; do
        if [ -d "$dir" ]; then
            cd "$dir"
            for lib in *.so.*; do
                [ -f "$lib" ] || continue
                # Extract base name (e.g., libexpat.so.1 from libexpat.so.1.9.2)
                base=$(echo "$lib" | sed -E 's/(\.so\.[0-9]+).*/\1/')
                if [ "$base" != "$lib" ] && [ ! -e "$base" ]; then
                    ln -sf "$lib" "$base"
                fi
            done
        fi
    done
    cd /
fi

_ts "ldconfig: done"

# SSH and networking are NOT required for the kiosk to start.
# Run them in a background subshell so the kiosk launches immediately after udev.
(
    _ts "bg-services: START"

    _ts "network: START"
    if [ -d /sys/class/net/eth0 ]; then
        /sbin/ip link set eth0 up
        echo "Starting DHCP on eth0..."
        timeout 10 /sbin/udhcpc -i eth0 -s /usr/share/udhcpc/default.script >/dev/null 2>&1
        if [ $? -ne 0 ]; then
            echo "DHCP failed, setting fallback static IP on eth0..."
            /sbin/ip addr add 10.0.2.15/24 dev eth0
            /sbin/ip route add default via 10.0.2.2 dev eth0 2>/dev/null || true
        fi
    else
        echo "No eth0 interface found!"
    fi
    _ts "network: done"

    # Set root password to 'alpine'
    if command -v chpasswd >/dev/null 2>&1; then
        if echo "root:alpine" | chpasswd; then
            echo "Root password configured."
        else
            echo "WARNING: Failed to set root password via chpasswd"
            [ -f /etc/shadow ] || echo "WARNING: /etc/shadow missing"
        fi
    else
        echo "WARNING: chpasswd not found"
    fi
    _ts "chpasswd: done"

    # Start SSH server
    mkdir -p /var/empty /var/run /run /etc/ssh/sshd_config.d /root/.ssh
    chmod 700 /root/.ssh

    cat > /etc/ssh/sshd_config.d/10-root-password.conf <<'SSHEOF'
PermitRootLogin yes
PasswordAuthentication yes
KbdInteractiveAuthentication no
SSHEOF

    # Generate host keys only if not pre-generated at build time
    if [ ! -f /etc/ssh/ssh_host_rsa_key ]; then
        _ts "ssh-keygen: START"
        command -v ssh-keygen >/dev/null 2>&1 && ssh-keygen -A >/dev/null 2>&1
        _ts "ssh-keygen: done"
    fi

    # Start sshd (search only standard paths; no filesystem-wide find)
    SSHD_PATH=""
    for path in /usr/sbin/sshd /sbin/sshd /usr/bin/sshd /bin/sshd; do
        if [ -x "$path" ]; then SSHD_PATH="$path"; break; fi
    done
    if [ -n "$SSHD_PATH" ]; then
        "$SSHD_PATH" -D &
    else
        echo "WARNING: sshd binary not found!"
    fi
    _ts "sshd: started"
) &

echo "kiosk-tauri started"

# Start kiosk app on TTY1 via cage Wayland compositor
export XDG_RUNTIME_DIR=/run/user/0
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR"

# seatd is needed for cage to access DRM without root privilege dance
seatd -g root &
# Poll for seatd socket instead of sleeping a fixed 1s
_wait=0
while [ ! -S /run/seatd.sock ] && [ $_wait -lt 5 ]; do
    /bin/busybox usleep 100000
    _wait=$((_wait + 1))
done
_ts "seatd: ready"

# Launch cage with the Tauri kiosk app on TTY1.
# openvt may not preserve env reliably, so export vars in a child script.
cat > /run/start-kiosk.sh <<'EOF'
#!/bin/sh
export XDG_RUNTIME_DIR=/run/user/0
export LIBSEAT_BACKEND=seatd

export WLR_XWAYLAND=0

export WLR_RENDERER_ALLOW_SOFTWARE=1
export WLR_NO_HARDWARE_CURSORS=1

export GDK_BACKEND=wayland
export WEBKIT_DISABLE_COMPOSITING_MODE=0
export XCURSOR_THEME=Adwaita
export XCURSOR_SIZE=24
export GTK_CSD=0

export LC_ALL=C
export LANG=C

export XKB_DEFAULT_RULES=evdev
export XKB_DEFAULT_MODEL=pc105
export XKB_DEFAULT_LAYOUT=us
export XKB_DEFAULT_VARIANT=""
export XKB_DEFAULT_OPTIONS=""

export LIBINPUT_LOG_PRIORITY=debug

# Mesa shader cache: use tmpfs-backed dir so Mesa can cache shaders within the session.
# Without this, Mesa/LLVM recompiles shaders on every GL context creation.
export MESA_SHADER_CACHE_DIR=/tmp/mesa-shader-cache
mkdir -p "$MESA_SHADER_CACHE_DIR"

echo "$(cat /proc/uptime | cut -d' ' -f1) cage: starting" >> /run/boot-timing.log
exec cage -d -- /opt/kiosk/tauri_welcome >>/run/kiosk.log 2>&1
EOF
chmod +x /run/start-kiosk.sh

_ts "cage: launched"
openvt -c 1 -s -w -- /run/start-kiosk.sh &

exec sleep infinity
